{
  "name": "tricklets.github.io",
  "type": "module",
  "version": "0.1.1-rc.4",
  "private": true,
  "packageManager": "pnpm@11.1.3+sha512.c85357fe17ca12dd23dd7071822666dfd7e3cb76fe214e3370b5ea2fb34f2a231185509b63e717f3cd0acb38dd3f8d82bcd5e8172400ae678b70ea4fbed0896d",
  "scripts": {
    "setup": "pnpm install --frozen-lockfile",
    "clean": "rimraf node_modules/.cache dist && pnpm -r --if-present --parallel run clean",
    "build": "mkdir -p dist/image && pnpm run -r --parallel --if-present build"
  },
  "devDependencies": {
    "fixme": "0.7.0",
    "rimraf": "6.1.3"
  },
  "trustPolicy": "strict",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.0.0",
      "onFail": "download"
    }
  },
  "changelog": {
    "labels": {
      "Type: Breaking": "💥 Breaking Change",
      "Type: Feature": "🎉 New Feature",
      "Type: Enhancement": "🚀 Enhancement",
      "Type: Security": "🛡️ Security",
      "Type: BugFix": "💉 Bug Fix",
      "Type: Deprecated": "⚠️ Deprecated",
      "Type: Docs": "📝 Documentation",
      "Type: Refactoring": "✨ Refactoring",
      "Type: Testing": "✅ Testing",
      "Type: Build": "🛠️ Build",
      "Type: Dependency": "📦 Dependency",
      "Type: Misc": "🧩 misc"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tricklets/tricklets.github.io",
    "productOwners": [
      "tricklets-po"
    ]
  },
  "author": "tricklets (https://github.com/tricklets)",
  "license": "UNLICENSED"
}
